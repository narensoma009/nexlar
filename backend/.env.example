AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-10-21

# Local SQLite (zero install). On Azure, use a path under /home/data so it persists across restarts:
#   sqlite:////home/data/nexlara.db
DATABASE_URL=sqlite:///./nexlara.db

# Must match the dim of your embedding deployment (text-embedding-3-small=1536, text-embedding-3-large=3072, ada-002=1536)
EMBEDDING_DIM=1536
RAG_TOP_K=5
