AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-10-21

# Postgres with pgvector. For local Docker: postgresql+psycopg2://nexlara:nexlara@localhost:5432/nexlara
# For Azure Flexible Server: postgresql+psycopg2://USER:PASSWORD@HOST.postgres.database.azure.com:5432/DB?sslmode=require
DATABASE_URL=postgresql+psycopg2://nexlara:nexlara@localhost:5432/nexlara

# Must match the dim of your embedding deployment (text-embedding-3-small=1536, text-embedding-3-large=3072, ada-002=1536)
EMBEDDING_DIM=1536
RAG_TOP_K=5
